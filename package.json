{
  "name": "rule-mcp",
  "version": "0.1.0",
  "description": "MCP server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "reinstall": "rm -rf node_modules package-lock.json && npm install",
    "rebuild": "npm run reinstall && npm run clean && npm run build",
    "use-verdaccio": "echo '@rulecom:registry=http://localhost:4873' > .npmrc && npm install",
    "use-npm": "rm -f .npmrc && npm install"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@rulecom/sdk": "^0.4.0-beta.7",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "^5.0.0",
    "vitest": "^4.1.6"
  }
}
